{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "ELECTRON_SKIP_BINARY_DOWNLOAD=1 npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "routes": [
    {
      "src": "/env\\.js$",
      "headers": {
        "Cache-Control": "no-cache, no-store, must-revalidate"
      }
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
